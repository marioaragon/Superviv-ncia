install.packages("knitr")
library(knitr)
library(survival)
data<-read.table("whas100.txt", header = T)
data$fstat <- factor(data$fstat, levels = c(0, 1), labels = c("censurat", "observat"))
data$fage <- factor(data$fage, levels = c(0, 1), labels = c("<70", "70+"))
data$fbmi <- factor(data$fbmi, levels = c(0, 1), labels = c("<25", "25+"))
data$gender <- factor(data$gender, levels = c(0, 1), labels = c("Home", "Dona"))
str(data)
n.var2 <- names(data)
kable(data.frame(Variables= n.var2[c(1,2,4,6,7)], Descripció= c("Temps en dies fins la mort del pacient","Indicador de censura per la dreta (0=censurat; 1=observat)","Gènere del pacient (0=Home, 1=Dona)
","Edat (0=menors de 70 anys (70-), 1=majors de 70 anys (70+))
","Índex massa corporal (kg/m^2) (0=Baix (menys de 25), 1=Alt (més de 25))")))
View(data)
n.var2 <- names(data)
kable(data.frame(Variables= n.var2[c(1,2,4,6,7)], Descripció= c("Temps en dies fins la mort del pacient","Indicador de censura per la dreta (censurat/observat)","Gènere del pacient (0=Home, 1=Dona)
","Edat (menors de 70 anys (<70), majors de 70 anys (70+))
","Índex massa corporal (kg/m^2) (Baix (menys de 25), Alt (25+))")))
View(data)
